<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/habit_widget_root"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@drawable/habit_widget_background"
  android:orientation="vertical"
  android:padding="14dp">

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <LinearLayout
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:orientation="vertical">

      <TextView
        android:id="@+id/habit_widget_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="#F8FAFC"
        android:textSize="18sp"
        android:textStyle="bold" />

      <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <View
          android:layout_width="8dp"
          android:layout_height="8dp"
          android:background="@drawable/habit_widget_dot" />

        <TextView
          android:id="@+id/habit_widget_streak"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_marginStart="6dp"
          android:ellipsize="end"
          android:maxLines="1"
          android:textColor="#D5F5EA"
          android:textSize="13sp" />
      </LinearLayout>
    </LinearLayout>

    <TextView
      android:id="@+id/habit_widget_done"
      android:layout_width="42dp"
      android:layout_height="42dp"
      android:layout_marginStart="12dp"
      android:background="@drawable/habit_widget_done_background"
      android:gravity="center"
      android:text="✓"
      android:textColor="#6B7280"
      android:textSize="24sp"
      android:textStyle="bold" />
  </LinearLayout>

  <GridLayout
    android:id="@+id/habit_widget_grid"
    android:layout_width="match_parent"
    android:layout_height="0dp"
    android:layout_marginTop="16dp"
    android:layout_weight="1"
    android:alignmentMode="alignBounds"
    android:columnCount="21"
    android:gravity="center_horizontal"
    android:rowCount="4"
    android:useDefaultMargins="false" />
</LinearLayout>
