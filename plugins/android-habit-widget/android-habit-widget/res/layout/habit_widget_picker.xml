<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="#07111F"
  android:orientation="vertical"
  android:paddingStart="24dp"
  android:paddingTop="56dp"
  android:paddingEnd="24dp"
  android:paddingBottom="24dp">

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <TextView
      android:layout_width="48dp"
      android:layout_height="48dp"
      android:background="@drawable/habit_widget_app_badge"
      android:gravity="center"
      android:text="✓"
      android:textColor="#07111F"
      android:textSize="28sp"
      android:textStyle="bold" />

    <TextView
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginStart="14dp"
      android:text="HabitAI"
      android:textColor="#5EEAD4"
      android:textSize="22sp"
      android:textStyle="bold" />
  </LinearLayout>

  <TextView
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="28dp"
    android:text="Select a Habit"
    android:textColor="#F8FAFC"
    android:textSize="34sp"
    android:textStyle="bold" />

  <TextView
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    android:text="Choose a real HabitAI habit for your home screen"
    android:textColor="#9FB2CC"
    android:textSize="17sp" />

  <View
    android:layout_width="match_parent"
    android:layout_height="1dp"
    android:layout_marginTop="24dp"
    android:background="#263A56" />

  <TextView
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="24dp"
    android:letterSpacing="0.08"
    android:text="YOUR HABITS"
    android:textColor="#6B7280"
    android:textSize="13sp"
    android:textStyle="bold" />

  <ListView
    android:id="@+id/habit_picker_list"
    android:layout_width="match_parent"
    android:layout_height="0dp"
    android:layout_marginTop="14dp"
    android:layout_weight="1"
    android:divider="@android:color/transparent"
    android:dividerHeight="12dp"
    android:listSelector="@android:color/transparent" />
</LinearLayout>
